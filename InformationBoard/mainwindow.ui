  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #f0f0f0;
}

QGroupBox {
    font-weight: bold;
    border: 2px solid #cccccc;
    border-radius: 5px;
    margin-top: 10px;
    padding-top: 10px;
    background-color: white;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px 0 5px;
    color: #2c3e50;
}

QPushButton {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 8px;
    border-radius: 4px;
    font-weight: bold;
    min-height: 30px;
}

QPushButton:hover {
    background-color: #2980b9;
}

QPushButton:pressed {
    background-color: #1c5a8a;
}

QPushButton[text^=&quot;📰&quot;], 
QPushButton[text^=&quot;☀️&quot;], 
QPushButton[text^=&quot;🕐&quot;], 
QPushButton[text^=&quot;🏢&quot;] {
    background-color: #27ae60;
    font-size: 14px;
}

QPushButton[text^=&quot;📰&quot;]:hover,
QPushButton[text^=&quot;☀️&quot;]:hover,
QPushButton[text^=&quot;🕐&quot;]:hover,
QPushButton[text^=&quot;🏢&quot;]:hover {
    background-color: #229954;
}

QLineEdit {
    padding: 8px;
    border: 2px solid #bdc3c7;
    border-radius: 4px;
    background-color: white;
    font-size: 14px;
}

QLineEdit:focus {
    border-color: #3498db;
}

QTabWidget::pane {
    border: 2px solid #cccccc;
    border-radius: 5px;
    background-color: white;
}

QTabBar::tab {
    background-color: #e0e0e0;
    padding: 10px 20px;
    margin-right: 2px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
}

QTabBar::tab:selected {
    background-color: white;
    border-bottom: 3px solid #3498db;
}

QTabBar::tab:hover {
    background-color: #d0d0d0;
}

QRadioButton, QCheckBox {
    spacing: 5px;
    color: #2c3e50;
}

QRadioButton::indicator, QCheckBox::indicator {
    width: 18px;
    height: 18px;
}

QComboBox {
    padding: 5px;
    border: 2px solid #bdc3c7;
    border-radius: 4px;
    background-color: white;
    min-height: 25px;
}

QComboBox:hover {
    border-color: #3498db;
}

QStatusBar {
    background-color: #2c3e50;
    color: white;
    font-weight: bold;
}</string>
  </property>
